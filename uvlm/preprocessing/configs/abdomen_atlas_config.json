{
    "dataset_name": "Dataset145_AbdomenAtlas3.0Mini",
    "dataset_id": "Dataset145_AbdomenAtlas3.0Mini",
    "description": "AbdomenAtlas 3.0 Mini - Abdominal Segmentation/Classification/Report Dataset",
    "body_region": "abdomen",

    "image": {
        "patch_size": [192, 256, 256],
        "spacing": [1.5, 1.0, 1.0],
        "orientation": "LPS"
    },

    "processing_params": {
        "target_size": [192, 256, 256],
        "target_orientation": "LPS",
        "output_format": "blosc2",
        "compression_level": 8
    },

    "paths": {
        "preprocessed": "/path/to/nnUNet_preprocessed/Dataset145_AbdomenAtlas3.0Mini",
        "meta_csv": "/path/to/AbdomenAtlas3.0MiniWithMeta.csv",
        "mask_only_dir": "/path/to/mask_only",
        "image_only_dir": "/path/to/image_only",
        "split_dir": "/path/to/TrainTestIDS",
        "images": "{preprocessed}/imagesTr",
        "image_filename_pattern": "{case_id}_0000.b2nd",
        "labels": "{preprocessed}/labelsTr_{scope}",
        "seg_csv": "{preprocessed}/{data_split}_train_{scope}.csv",
        "train_seg_csv": "{preprocessed}/dataset_train_{scope}.csv",
        "val_seg_csv": "{preprocessed}/dataset_val_{scope}.csv",
        "dataset_json": "{preprocessed}/dataset_{scope}.json",
        "train_csv": "{preprocessed}/iid_train_merged.csv",
        "validation_csv": "{preprocessed}/iid_test_merged.csv",
        "iid_train_csv": "{preprocessed}/iid_train_merged.csv",
        "iid_test_csv": "{preprocessed}/iid_test_merged.csv",
        "iid_test_seg_csv": "{preprocessed}/iid_test_merged.csv",
        "ood_train_csv": "{preprocessed}/ood_train_merged.csv",
        "ood_test_csv": "{preprocessed}/ood_test_merged.csv",
        "ood_test_seg_csv": "{preprocessed}/ood_test_merged.csv"
    },

    "reports": {
        "meta_csv": "AbdomenAtlas3.0MiniWithMeta.csv",
        "output_dir": "reports_processed",
        "id_column": "BDMAP ID",
        "report_targets": {
            "structured": {
                "source_column": "structured report",
                "target_column": "report_structured",
                "description": "Structured report format"
            },
            "narrative": {
                "source_column": "narrative report",
                "target_column": "report_narrative",
                "description": "Narrative report format"
            },
            "fusion_structured": {
                "source_column": "fusion structured report",
                "target_column": "report_fusion_structured",
                "description": "Fusion structured report with additional context"
            },
            "fusion_narrative": {
                "source_column": "fusion narrative report",
                "target_column": "report_fusion_narrative",
                "description": "Fusion narrative report with additional context"
            }
        },
        "default_target": "structured"
    },

    "classification": {
        "source": "segmentation_mask",
        "output_dir": "classification_processed",
        "num_classes": 3,
        "multi_label": true,
        "columns": [
            "Liver lesion",
            "Kidney lesion",
            "Pancreas lesion"
        ],
        "lesion_file_to_cls": {
            "liver_lesion": "Liver lesion",
            "kidney_lesion": "Kidney lesion",
            "pancreatic_lesion": "Pancreas lesion"
        },
        "meta_volume_mapping": {
            "Liver lesion": "total liver lesion volume (cm^3)",
            "Kidney lesion": "total kidney lesion volume (cm^3)",
            "Pancreas lesion": "total pancreatic lesion volume (cm^3)"
        }
    },

    "split_method": {
        "method": "iid_ood",
        "split_dir": "TrainTestIDS",
        "id_column": "case_id",
        "files": {
            "iid_train": "IID_train.csv",
            "iid_test": "IID_test.csv",
            "ood_train": "OOD_train.csv",
            "ood_test": "OOD_test.csv"
        }
    },

